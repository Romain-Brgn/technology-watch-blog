@{
    ViewData["Title"] = "Accueil";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Technology Watch Blog</h1>
        <p class="lead">
            Une plateforme de veille technologique alimentée automatiquement par flux RSS.
        </p>
        <p>
            Retrouvez des articles centralisés, consultables sur un format homogène,
            avec à terme une recherche assistée par IA basée sur les contenus enregistrés en base.
        </p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h2 class="h5">Articles centralisés</h2>
                    <p class="card-text">
                        Les articles issus de différentes sources RSS sont importés,
                        stockés en base de données puis affichés sur le site.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h2 class="h5">Lecture uniforme</h2>
                    <p class="card-text">
                        Chaque article dispose de sa propre page avec un rendu visuel cohérent
                        et un accès direct vers la source d’origine.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h2 class="h5">Assistant IA</h2>
                    <p class="card-text">
                        Une fonctionnalité permettra d’interroger les articles enregistrés
                        pour obtenir des synthèses thématiques et des liens internes pertinents.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>