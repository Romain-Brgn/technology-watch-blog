@{
    ViewData["Title"] = "AI Tech Watch";
}

<section class="home-page">
    <div class="hero">
        <p class="eyebrow">Veille technologique augmentée par IA</p>

        <h1>AI Tech Watch</h1>

        <p class="subtitle">
            Posez une question. Obtenez une réponse basée sur des articles tech récents et sourcés.
        </p>

        <div class="counter-card">
            <span class="counter-number">@ViewBag.ArticleCount</span>
            <span class="counter-label">articles disponibles</span>
        </div>

        <div class="ask-wrapper">
            <div class="ask-box">
                <input id="question"
                       type="text"
                       placeholder="Ex: What are AI agents?" />

                <button onclick="askAI()">
                    Ask →
                </button>
            </div>
        </div>

        
    </div>

    <div class="result-panel">
        <div class="result-section">
            <h2>✨ Réponse de l'IA</h2>
            <div id="loading" class="loading">Génération en cours...</div>
            <div id="answer" class="answer-placeholder">
                Posez votre question pour obtenir une réponse.
            </div>
        </div>

        <div class="result-section sources-section">
            <h2>🔗 Sources</h2>
            <div id="sources" class="sources-placeholder">
                Les articles utilisés apparaîtront ici.
            </div>
        </div>
    </div>
</section>

<style>
    body.app-body {
        margin: 0;
        background:
            radial-gradient(circle at top left, rgba(124, 58, 237, .25), transparent 35%),
            radial-gradient(circle at top right, rgba(6, 182, 212, .22), transparent 35%),
            #08111f;
        color: #f8fafc;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        min-height: 100vh;
    }

    .app-header {
        background: rgba(8, 17, 31, .82);
        backdrop-filter: blur(18px);
        border-bottom: 1px solid rgba(148, 163, 184, .15);
    }

    .app-navbar {
        max-width: 980px;
        margin: 0 auto;
        height: 76px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 64px;
    }

    .app-brand {
        color: #fff;
        font-size: 1.15rem;
        font-weight: 800;
        text-decoration: none;
    }

    .app-nav-links {
        display: flex;
        gap: 28px;
    }

    .app-nav-links a {
        color: #cbd5e1;
        text-decoration: none;
        font-weight: 600;
    }

    .app-nav-links a:hover {
        color: #67e8f9;
    }

    .home-page {
        min-height: calc(100vh - 76px);
        padding: 70px 24px;
    }

    .hero {
        max-width: 940px;
        margin: 0 auto;
        text-align: center;
    }

    .eyebrow {
        color: #67e8f9;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        font-size: .78rem;
    }

    h1 {
        font-size: clamp(3rem, 7vw, 5.5rem);
        line-height: 1;
        margin: 18px 0;
        background: linear-gradient(90deg, #a855f7, #38bdf8, #22d3ee);
        -webkit-background-clip: text;
        color: transparent;
        font-weight: 900;
    }

    .subtitle {
        max-width: 680px;
        margin: 0 auto 32px;
        color: #b6c2d6;
        font-size: 1.2rem;
        line-height: 1.7;
    }

    .counter-card {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        padding: 18px 30px;
        border-radius: 22px;
        background: rgba(15, 23, 42, .7);
        border: 1px solid rgba(56, 189, 248, .35);
        box-shadow: 0 0 35px rgba(56, 189, 248, .12);
        margin-bottom: 42px;
    }

    .counter-number {
        font-size: 1.7rem;
        font-weight: 800;
        background: -webkit-linear-gradient(#06b6d4, #3b82f6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .counter-label {
        color: #e2e8f0;
        font-weight: 600;
    }

    .ask-wrapper {
        max-width: 820px;
        margin: 0 auto;
        padding: 2px;
        border-radius: 20px;
        background: linear-gradient(120deg, #a855f7, #06b6d4, #0a2755, #250a3f);
        background-size: 300% 300%;
        animation: borderMove 5s ease infinite;
        box-shadow: 0 0 32px rgba(6, 182, 212, .28);
    }

    @@keyframes borderMove {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }

    .ask-box {
        display: flex;
        gap: 12px;
        background: #0f172a;
        border-radius: 18px;
        padding: 14px;
    }

    .ask-box input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: #f8fafc;
        font-size: 1rem;
        padding: 12px 16px;
    }

    .ask-box input::placeholder {
        color: #64748b;
    }

    .ask-box button {
        border: none;
        color: white;
        font-weight: 800;
        border-radius: 14px;
        padding: 12px 28px;
        cursor: pointer;
        background: linear-gradient(120deg, #ab3aed, #090774);
        box-shadow: 0 0 22px rgba(124, 58, 237, .45);
    }

    .enter-hint {
        color: #94a3b8;
        margin-top: 16px;
    }

    .enter-hint span {
        border: 1px solid rgba(148, 163, 184, .4);
        border-radius: 6px;
        padding: 3px 8px;
        color: #e2e8f0;
    }

    .result-panel {
        max-width: 940px;
        margin: 52px auto 0;
        border: 1px solid rgba(148, 163, 184, .18);
        border-radius: 24px;
        background: rgba(15, 23, 42, .62);
        backdrop-filter: blur(18px);
        overflow: hidden;
    }

    .result-section {
        padding: 28px;
    }

    .result-section + .result-section {
        border-top: 1px solid rgba(148, 163, 184, .14);
    }

    .result-section h2 {
        font-size: 1.1rem;
        margin-bottom: 18px;
    }

    .answer-placeholder,
    .sources-placeholder,
    .answer-card,
    .source-card {
        color: #cbd5e1;
        background: rgba(8, 17, 31, .55);
        border: 1px solid rgba(148, 163, 184, .12);
        border-radius: 16px;
        padding: 20px;
        line-height: 1.7;
    }

    .loading {
        display: none;
        color: #67e8f9;
        margin-bottom: 14px;
    }

    .source-card {
        margin-top: 12px;
    }

    .source-card a {
        color: #67e8f9;
        text-decoration: none;
        font-weight: 700;
    }

    @@media (max-width: 720px) {
        .app-navbar {
            gap: 24px;
            flex-direction: column;
            height: auto;
            padding: 18px;
        }

        .ask-box {
            flex-direction: column;
        }

        .ask-box button {
            width: 100%;
        }
    }
    @@media (max-width: 480px) {
    .home-page {
        padding: 48px 16px;
    }

    .counter-card {
        flex-direction: column;
        gap: 4px;
    }

    .subtitle {
        font-size: 1rem;
    }
}
</style>

<script>
document.getElementById("question").addEventListener("keydown", function (e) {
    if (e.key === "Enter") {
        askAI();
    }
});

async function askAI() {
    const questionInput = document.getElementById("question");
    const question = questionInput.value.trim();

    if (!question) return;

    const loading = document.getElementById("loading");
    const answer = document.getElementById("answer");
    const sources = document.getElementById("sources");

    loading.style.display = "block";
    answer.innerHTML = "";
    sources.innerHTML = "";

    try {
        const res = await fetch(`/Assistant/Ask?question=${encodeURIComponent(question)}`);

        if (!res.ok) {
            throw new Error("Erreur lors de la génération.");
        }

        const data = await res.json();

        answer.innerHTML = `
            <div class="answer-card">
                ${data.answer.replace(/\n/g, "<br>")}
            </div>
        `;

        sources.innerHTML = "";

        data.sources.forEach(s => {
            sources.innerHTML += `
                <div class="source-card">
                    <a href="${s.url}">${s.title}</a>
                </div>
            `;
        });
    } catch (error) {
        answer.innerHTML = `<div class="answer-card">Une erreur est survenue. Réessayez.</div>`;
    } finally {
        loading.style.display = "none";
    }
}
</script>