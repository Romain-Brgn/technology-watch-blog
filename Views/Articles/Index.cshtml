@model List<TechnologyWatchBlog.Models.Article>

@{
    ViewData["Title"] = "Articles";
}

<section class="articles-page">
    <div class="articles-hero">
        <p class="eyebrow">Base de veille</p>
        <h1>Articles</h1>
        <p class="subtitle">
            Explorez les articles collectés automatiquement depuis les flux dev.to.
        </p>

        <form method="get" class="articles-filters">
            <select name="sort">
                <option value="">Plus récents</option>
                <option value="old" selected="@(ViewBag.CurrentSort == "old")">Plus anciens</option>
            </select>

            @{
    var selectedTags = ViewBag.CurrentTags as List<string> ?? new List<string>();
}

    <details class="tag-dropdown">
        <summary>
            @(selectedTags.Any()
                ? $"{selectedTags.Count} tag(s) sélectionné(s)"
                : "Choisir des tags")
        </summary>

        <div class="tag-options">
            @foreach (var tag in ViewBag.AllTags)
            {
                var isChecked = selectedTags.Contains(tag);

                <label>
                    <input type="checkbox"
                           name="tags"
                           value="@tag"
                           checked="@isChecked" />
                    @tag
                </label>
            }
        </div>
    </details>
            

            <button type="submit">Filtrer</button>
        </form>
    </div>

    <div class="articles-grid">
        @foreach (var article in Model)
        {
            <article class="article-card">
                <div>
                    <p class="article-date">
                        @(article.PublishedAt?.ToString("dd/MM/yyyy") ?? "Date inconnue")
                    </p>

                    <h2>@article.Title</h2>

                    <p class="article-excerpt">
                        @article.Excerpt
                    </p>
                </div>

                <div class="article-footer">
                    @if (!string.IsNullOrWhiteSpace(article.Tags))
                    {
                        <p class="article-tags">@article.Tags</p>
                    }

                    <a asp-controller="Articles"
                       asp-action="Details"
                       asp-route-slug="@article.Slug">
                        Lire l'article →
                    </a>
                </div>
            </article>
        }
    </div>
</section>

<style>
    .articles-filters select[multiple] {
    min-height: 120px;
    }

    .filter-help {
        color: #64748b;
        font-size: .85rem;
        margin-top: 10px;
        text-align: center;
    }
    .articles-page {
    position: relative;
    min-height: calc(100vh - 76px);
    padding: 70px 24px;
    overflow: hidden;
    }

    .articles-page::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        background:
            radial-gradient(circle at top left, rgba(124, 58, 237, .25), transparent 35%),
            radial-gradient(circle at top right, rgba(6, 182, 212, .22), transparent 35%),
            #08111f;
    }

    .articles-hero {
        max-width: 980px;
        margin: 0 auto 48px;
        text-align: center;
    }

    .articles-hero h1 {
        font-size: clamp(3rem, 7vw, 5rem);
        line-height: 1;
        margin: 18px 0;
        background: linear-gradient(90deg, #a855f7, #38bdf8, #22d3ee);
        -webkit-background-clip: text;
        color: transparent;
        font-weight: 900;
    }

    .eyebrow {
        color: #67e8f9;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        font-size: .78rem;
    }

    .subtitle {
        max-width: 680px;
        margin: 0 auto 32px;
        color: #b6c2d6;
        font-size: 1.1rem;
        line-height: 1.7;
    }

    .articles-filters {
        max-width: 820px;
        margin: 0 auto;
        display: flex;
        gap: 12px;
        padding: 14px;
        border-radius: 20px;
        background: rgba(15, 23, 42, .72);
        border: 1px solid rgba(148, 163, 184, .16);
        backdrop-filter: blur(18px);
    }

    .articles-filters input,
    .articles-filters select {
        flex: 1;
        background: rgba(8, 17, 31, .8);
        border: 1px solid rgba(148, 163, 184, .16);
        color: #f8fafc;
        border-radius: 14px;
        padding: 12px 14px;
        outline: none;
    }

    .articles-filters button {
        border: none;
        color: white;
        font-weight: 800;
        border-radius: 14px;
        padding: 12px 24px;
        cursor: pointer;
        background: linear-gradient(120deg, #7c3aed, #06b6d4);
        box-shadow: 0 0 22px rgba(124, 58, 237, .35);
    }

    .articles-grid {
        max-width: 1180px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
        gap: 22px;
    }

    .article-card {
        min-height: 280px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 24px;
        border-radius: 22px;
        background: rgba(15, 23, 42, .68);
        border: 1px solid rgba(148, 163, 184, .14);
        box-shadow: 0 0 35px rgba(6, 182, 212, .06);
    }

    .article-date {
        color: #67e8f9;
        font-size: .82rem;
        font-weight: 700;
        margin-bottom: 12px;
    }

    .article-card h2 {
        color: #f8fafc;
        font-size: 1.2rem;
        line-height: 1.35;
        margin-bottom: 14px;
    }

    .article-excerpt {
        color: #94a3b8;
        line-height: 1.65;
        font-size: .95rem;
    }

    .article-tags {
        color: #64748b;
        font-size: .82rem;
        margin-bottom: 14px;
    }

    .article-footer a {
        color: #67e8f9;
        text-decoration: none;
        font-weight: 800;
    }

    @@media (max-width: 720px) {
        .articles-page {
            padding: 48px 16px;
        }

        .articles-filters {
            flex-direction: column;
        }

        .articles-filters button {
            width: 100%;
        }
    }
    .tag-dropdown {
    flex: 1;
    position: relative;
}

.tag-dropdown summary {
    list-style: none;
    cursor: pointer;
    background: rgba(8, 17, 31, .8);
    border: 1px solid rgba(148, 163, 184, .16);
    color: #f8fafc;
    border-radius: 14px;
    padding: 12px 14px;
}

.tag-dropdown summary::-webkit-details-marker {
    display: none;
}

.tag-options {
    position: absolute;
    z-index: 10;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: #0f172a;
    border: 1px solid rgba(148, 163, 184, .18);
    border-radius: 14px;
    padding: 12px;
    display: grid;
    gap: 8px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, .35);
}

.tag-options label {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #cbd5e1;
    cursor: pointer;
}
</style>