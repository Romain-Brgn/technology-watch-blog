@model List<TechnologyWatchBlog.Models.Article>

@{
    ViewData["Title"] = "Articles";
}

<div class="container py-5">
    <h1 class="mb-4">Articles</h1>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Aucun article n'est encore disponible.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var article in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrWhiteSpace(article.ImageUrl))
                        {
                            <img src="@article.ImageUrl" class="card-img-top" alt="@article.Title" />
                        }

                        <div class="card-body d-flex flex-column">
                            <h2 class="h5 card-title">
                                <a asp-controller="Articles"
                                asp-action="Details"
                                asp-route-slug="@article.Slug"
                                class="text-decoration-none text-dark">
                                    @article.Title
                                </a>
                            </h2>

                            <p class="text-muted small mb-2">
                                @(article.PublishedAt?.ToLocalTime().ToString("dd/MM/yyyy") ?? "Date inconnue")
                                · @article.SourceName
                            </p>

                            <p class="card-text flex-grow-1">@article.Excerpt</p>

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <a href="@article.SourceUrl" target="_blank" class="btn btn-outline-secondary btn-sm">
                                    Source
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>